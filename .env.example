# 在线 SQLite（Turso / libSQL）— 配置后多终端共享同一数据库
# 注册 https://turso.tech 创建数据库后填写：
# YANYUAN_INSPECTION_DATABASE_URL=libsql://your-db-name-username.turso.io
# YANYUAN_INSPECTION_AUTH_TOKEN=your-auth-token

# 未配置上述变量时，使用本地文件（默认 yanyuan_inspection.db）
# YANYUAN_INSPECTION_DB=F:/text2sql/yanyuan_inspection/yanyuan_inspection.db
